<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create Account - IGEC Marketplace</title>
    <style>
        /* Base Creamy Theme Colors */
        :root {
            --bg-creamy: #fdfbf7;      /* Light creamy background */
            --container-bg: #ffffff;   /* Pure white for the form card */
            --green-primary: #66bb6a;  /* Main light green */
            --green-hover: #4caf50;    /* Darker green for hover */
            --text-dark: #2c4c3b;      /* Dark greenish-gray for text */
            --border-light: #c8e6c9;   /* Very light green for borders */
        }

        /* Global Reset & Body Styling */
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: var(--bg-creamy);
            color: var(--text-dark);
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            /* Scrollable body */
            overflow-x: hidden;
            overflow-y: auto;
        }

        /* Container Styling */
        .container {
            max-width: 420px;
            margin: 40px auto;
            padding: 30px 40px;
            background-color: var(--container-bg);
            border-radius: 12px;
            /* Soft greenish shadow */
            box-shadow: 0 8px 24px rgba(102, 187, 106, 0.15);
        }

        /* Typography */
        h1 {
            text-align: center;
            color: #388e3c;
            font-size: 1.8rem;
            margin-bottom: 5px;
            font-weight: 700;
        }

        h2 {
            text-align: center;
            color: #607d8b;
            font-size: 1.1rem;
            margin-bottom: 30px;
            font-weight: 500;
        }

        /* Form Layout */
        form {
            display: flex;
            flex-direction: column;
            gap: 15px; /* Adds consistent spacing between all inputs */
        }

        label {
            font-weight: 600;
            font-size: 0.9rem;
            color: #4a6a57;
            margin-bottom: -8px; /* Pulls label slightly closer to input */
        }

        /* Input Fields & Select Dropdown */
        input, select {
            padding: 12px 15px;
            border: 1px solid var(--border-light);
            border-radius: 8px;
            font-size: 1rem;
            background-color: #fbfdfb; /* Faint green tint inside input */
            color: #333;
            transition: all 0.3s ease;
        }

        input::placeholder {
            color: #a5d6a7;
        }

        input:focus, select:focus {
            outline: none;
            border-color: var(--green-primary);
            box-shadow: 0 0 0 3px rgba(102, 187, 106, 0.2);
            background-color: #ffffff;
        }

        /* Submit Button */
        button[type="submit"] {
            margin-top: 15px;
            padding: 14px;
            background-color: var(--green-primary);
            color: white;
            border: none;
            border-radius: 8px;
            font-size: 1.1rem;
            font-weight: bold;
            cursor: pointer;
            transition: background-color 0.3s ease, transform 0.1s;
        }

        button[type="submit"]:hover {
            background-color: var(--green-hover);
        }

        button[type="submit"]:active {
            transform: scale(0.98);
        }

        /* Error box styling (in case your 'errors' include needs it) */
        .error-message {
            background-color: #ffebee;
            color: #d32f2f;
            padding: 10px;
            border-radius: 6px;
            font-size: 0.9rem;
            border-left: 4px solid #f44336;
        }

        /* Spacer to prevent bottom navbar from hiding the content */
        .space {
            color: transparent; 
            height: 20px; /* Base height for desktop */
        }
           .login-footer {
            margin-top: 25px;
            font-size: 16px;
            color: #181717;
        }

        .login-footer a {
            color: var(--primary-color);
            text-decoration: none;
            font-weight: 600;
            color: blue;
        }

        /* ========================================== */
        /* MOBILE RESPONSIVENESS & BOTTOM NAVBAR FIX  */
        /* ========================================== */
        @media (max-width: 768px) {
            .container {
                margin: 20px auto;
                width: 85%;
                padding: 25px 20px;
                /* Crucial Fix: Add massive margin/padding at the bottom 
                   so scrolling doesn't stop behind the bottom navbar */
                margin-bottom: 120px; 
            }
            
            .space {
                height: 80px; /* Extra transparent scrollable space */
            }
        }
    </style>
</head>
<body>

    <div class="container">
        <%- include('nav', { activePage: 'account' }) %>

        <h1>IGEC Marketplace</h1>
        <h2>Create Account</h2>

        <form action="/signup" method="POST">

            <%- include('errors') %>

    <label>Email</label>
            <input type="email" name="email"
                value="<%= OldInput && OldInput.email ? OldInput.email : '' %>"
                placeholder="example@gmail.com" required>

            <label>Name</label>
            <input type="text" name="username"
                value="<%= OldInput && OldInput.username ? OldInput.username : '' %>"
                placeholder="Enter Your Name" autocomplete="off" required>

        
            <label>Gender</label>
            <select name="gender" required>
                <option value="" disabled <%= !OldInput || !OldInput.gender ? 'selected' : '' %>>
                    Select Gender
                </option>
                <option value="male" <%= OldInput && OldInput.gender === 'male' ? 'selected' : '' %>>
                    Male
                </option>
                <option value="female" <%= OldInput && OldInput.gender === 'female' ? 'selected' : '' %>>
                    Female
                </option>
                <option value="other" <%= OldInput && OldInput.gender === 'other' ? 'selected' : '' %>>
                    Other
                </option>
            </select>

            <label>Password</label>
            <input type="password" name="password" placeholder="Create Password" required>

            <label>Confirm Password</label>
            <input type="password" name="confirmpass" placeholder="Confirm Password" required>

            <button type="submit">Create Account</button>

        </form>
          <div class="login-footer">
            Already have an account? <a href="/login">Login</a>
        </div>

        <div class="space">.</div>

    </div>

</body>
</html>