<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

<style>
/* GLOBAL RESET FOR NAV TO PREVENT SHIFTS */
nav, nav * {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
  font-family: 'Poppins', sans-serif;
}

/* MOBILE FIRST: BOTTOM NAVBAR */
nav {
  position: fixed;
  bottom: 0;
  left: 0; /* Ensures it starts exactly from the left edge */
  width: 100%;
  background: #ffffff;
  box-shadow: 0 -5px 20px rgba(0,0,0,0.08);
  z-index: 1000;
  border-top-left-radius: 20px;
  border-top-right-radius: 20px;
  /* Safe area padding for modern phones with curved bottom edges */
  padding-bottom: env(safe-area-inset-bottom); 
}

nav h3 {
  display: none;
}

nav ul {
  display: flex;
  justify-content: space-around;
  align-items: center;
  list-style: none;
  padding: 12px 0;
}

nav ul li a {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-decoration: none;
  color: #888;
  font-size: 12px;
  font-weight: 500;
  transition: all 0.3s ease;
}

nav ul li a i {
  font-size: 20px;
  margin-bottom: 4px;
  transition: all 0.3s ease;
}

/* ACTIVE & HOVER STATES */
nav ul li.active a,
nav ul li a:hover {
  color: #6c63ff;
}

nav ul li.active a i {
  transform: translateY(-3px) scale(1.1); /* Smoother bounce effect */
}

/* DESKTOP: TOP NAVBAR */
@media (min-width: 768px) { /* Standard tablet/desktop breakpoint */
  nav {
    top: 0;
    bottom: auto;
    border-radius: 0;
    padding: 15px 5%; /* Percentage padding keeps it responsive */
    display: flex;
    justify-content: space-between; /* Automatically pushes H3 to left and UL to right */
    align-items: center;
    box-shadow: 0 4px 15px rgba(0,0,0,0.05); /* Shadow at the bottom now */
  }

  nav h3 {
    display: block;
    font-size: 22px;
    font-weight: 600;
    color: #333;
    letter-spacing: 0.5px;
  }

  nav ul {
    justify-content: flex-end;
    gap: 35px; /* Spacing between links */
    padding: 0;
  }

  nav ul li a {
    flex-direction: row;
    gap: 8px;
    font-size: 15px;
    padding: 8px 12px;
    border-radius: 8px;
  }

  nav ul li a i {
    font-size: 16px;
    margin-bottom: 0;
  }

  nav ul li.active a i {
    transform: scale(1.1); /* Remove Y translation on desktop */
  }
}

/* GLOBAL BODY PADDING FOR DESKTOP */
/* Taaki content navbar ke piche hide na ho jaye */
@media (min-width: 768px) {
  body {
    padding-top: 80px; 
  }
}
</style>

<nav>
  <h3>IGEC E-Commerce Hub</h3>
  <ul>
    <li class="<%= activePage === 'home' ? 'active' : '' %>">
      <a href="/"><i class="fa fa-home"></i>Home</a>
    </li>
    <li class="<%= activePage === 'sell' ? 'active' : '' %>">
      <a href="/sell"><i class="fa fa-plus-circle"></i>Sell</a>
    </li>
    <li class="<%= activePage === 'chats' ? 'active' : '' %>">
      <a href="/chats"><i class="fa fa-box"></i>Chats</a>
    </li>
    <li class="<%= activePage === 'account' ? 'active' : '' %>">
      <a href="/account"><i class="fa fa-user"></i>Account</a>
    </li>
  </ul>
</nav>