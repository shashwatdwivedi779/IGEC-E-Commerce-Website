<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>IGEC Shop | Marketplace</title>
    <meta name="description" content="Exclusive marketplace for Indira Gandhi Engineering College students">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/home.css">

<script>
    
</script>

</head>
<body>
 <%- include('nav', { activePage: 'home' }) %>


 <a href="/" class="back-btn">
        <i class="fa-solid fa-arrow-left"></i> Back
    </a>  


    <form action="/search" method="POST" class="search-form">
            <input
                type="text"
                name="q"
                placeholder="Search products..."
                value="<%= searchQuery ? searchQuery : '' %>"
            >
            <button type="submit">Search</button>
        </form>

 <div class="message">
                Search results for "<%= searchQuery %>"
            </div>

    <main>
        <div class="card-container">
            <% if (products && products.length > 0) { %>
                <% products.forEach(product => { %>
                    <div class="card">
                        <img src="<%= product.imagepath || '/images/default-product.png' %>" alt="<%= product.productname %>">
                        <h3><%= product.productname %></h3>
                        <h4>₹<%= product.price || 0 %></h4>
                        <a href="/details/<%= product._id %>" class="buy-btn">View Details</a>
                    </div>
                <% }) %>
            <% } else { %>
                <p style="grid-column: 1/-1; text-align: center; color: #888;">
                    No Items Availble For Your Search
                </p>
            <% } %>
        </div>
    </main>

<%- include('futter') %>

</body>
</html>